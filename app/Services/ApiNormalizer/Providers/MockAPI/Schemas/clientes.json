{
    "provider": "mockAPI",
    "path": "bulk-data-clients",
    "method": "GET",
    "response": {
        "root": "data"
    },
    "canonical": {
        "entity": "Cliente",
        "schema": "\\app\\Services\\ApiNormalizer\\DTOs\\clientes.json"
    },
    "mapping": {
        "entity": "Cliente",
        "fields": {
            "clientId": {
                "type": "integer",
                "required": true,
                "field": "codigo_cliente"
            },
            "name": {
                "type": "string",
                "required": true,
                "field": "nome_cliente"
            },
            "document": {
                "type": "string",
                "required": false,
                "field": "cpf_cnpj"
            },
            "personType": {
                "type": "string",
                "required": false,
                "field": "tipo_pessoa"
            },
            "email": {
                "type": "string",
                "required": false,
                "field": "email"
            },
            "phone": {
                "type": "string",
                "required": false,
                "field": "telefone"
            },
            "birthDate": {
                "type": "date",
                "format": "Y-m-d",
                "required": false,
                "field": "data_nascimento"
            },
            "createdAt": {
                "type": "date",
                "format": "Y-m-d",
                "required": false,
                "field": "data_criacao_cliente"
            },
            "status": {
                "type": "string",
                "required": false,
                "field": "status_cliente"
            },
            "addressStreet": {
                "type": "string",
                "required": false,
                "field": "logradouro"
            },
            "addressNumber": {
                "type": "string",
                "required": false,
                "field": "numero"
            },
            "addressComplement": {
                "type": "string",
                "required": false,
                "field": "complemento"
            },
            "addressDistrict": {
                "type": "string",
                "required": false,
                "field": "bairro"
            },
            "addressCity": {
                "type": "string",
                "required": false,
                "field": "cidade"
            },
            "addressState": {
                "type": "string",
                "required": false,
                "field": "estado"
            },
            "addressZipCode": {
                "type": "string",
                "required": false,
                "field": "cep"
            }
        }
    },
    "casts": {
        "decimal": {
            "normalize": [
                "trim",
                {
                    "replace": {
                        "from": ".",
                        "to": ""
                    }
                },
                {
                    "replace": {
                        "from": ",",
                        "to": "."
                    }
                }
            ]
        },
        "date": {
            "normalize": [
                "trim"
            ]
        }
    }
}
